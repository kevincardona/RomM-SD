{
  "name": "romm-sd",
  "productName": "ROMM-SD",
  "private": false,
  "license": "GPL-3.0-only",
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "build": {
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "package.json",
      "build/**/*",
      "electron/**/*",
      "node_modules/@kmamal/sdl/**/*"
    ],
    "asarUnpack": [
      "node_modules/@kmamal/sdl/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "kevincardona",
      "repo": "RomM-SD"
    }
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@kmamal/sdl": "^0.11.13",
    "electron-updater": "^6.8.3",
    "node-addon-api": "^8.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
